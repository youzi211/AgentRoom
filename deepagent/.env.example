# Secrets template. Copy this file to .env and never commit the filled .env.

# Required for live web research.
TAVILY_API_KEY=

# Recommended model configuration.
# For an OpenAI-compatible custom endpoint:
# MODEL_PROTOCOL=openai
# MODEL_BASE_URL=https://your-proxy.com/v1
# MODEL_NAME=your-model
# MODEL_API_KEY=sk-...

# For a provider-native model, leave MODEL_BASE_URL empty and use a provider
# prefixed model name such as openai:gpt-5.5 or anthropic:claude-sonnet-4-6.
MODEL_PROTOCOL=openai
MODEL_BASE_URL=
MODEL_NAME=openai:gpt-5.5
MODEL_API_KEY=

# Provider-native key aliases still work if you prefer them.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# Legacy aliases still work, but MODEL_* is preferred.
# DEEPAGENT_MODEL=openai:gpt-5.5
# CUSTOM_ENABLED=true
# CUSTOM_PROTOCOL=openai
# CUSTOM_BASE_URL=https://your-proxy.com/v1
# CUSTOM_API_KEY=sk-...
# CUSTOM_MODEL_NAME=your-model

# Optional runtime overrides.
# RESEARCH_MAX_RESULTS=5
# RESEARCH_TOPIC=general
# RESEARCH_INCLUDE_RAW_CONTENT=false
# RESEARCH_OUTPUT_DIR=runs
# RESEARCH_STREAM_UPDATES=true
