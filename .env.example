# Copy this file to .env and fill in your real values.
#
# Required for Agent LLM responses:
LLM_API_KEY=your-api-key-here

# Optional. Use an OpenAI-compatible endpoint.
LLM_BASE_URL=https://api.openai.com

# Optional. Any chat-completions compatible model available on your endpoint.
LLM_MODEL=gpt-4o-mini

# Optional backend port.
PORT=8080

# Logging configuration.
# LOG_FORMAT=text is convenient for local development; use json for production log collectors.
LOG_LEVEL=info
LOG_FORMAT=text
LOG_ADD_SOURCE=false

# Database configuration (required for persistence)
DB_DRIVER=mysql
MYSQL_DSN=agentroom:agentroom_password@tcp(127.0.0.1:3306)/agentroom?parseTime=true&charset=utf8mb4&loc=UTC
DB_AUTO_MIGRATE=true
