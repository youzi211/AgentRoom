# Copy this file to .env and fill in real values before running locally or
# with Docker Compose. Do not commit .env.

# Backend HTTP port when running the Go service directly on the host.
# Docker Compose keeps the container listening on 8080 internally.
PORT=8080

# Docker Compose published host ports.
# Change these if the server already uses 3306, 8080, or 5173.
BACKEND_HOST_PORT=8080
FRONTEND_HOST_PORT=5173
MYSQL_HOST_PORT=3306

# Base64-encoded 32-byte master key used to encrypt model Profile API keys.
# The Docker startup scripts generate this when it is blank. Back up the final
# value from .env in your secret manager: losing or changing it makes existing
# encrypted Profile keys undecryptable. Generate manually with:
#   openssl rand -base64 32
MODEL_CONFIG_ENCRYPTION_KEY=

# Legacy Go-runtime migration fallback. New deployments should create a `go`
# Profile in the Models admin page. These values are used only while no enabled
# database default exists for the Go runtime; they are never imported into MySQL.
# If LLM_API_KEY is empty, human chat still works; agent invocations surface
# visible system messages instead of crashing the backend.
LLM_BASE_URL=https://api.openai.com
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-4o-mini

# Legacy DeepAgent model fallback. A database `deepagent` Profile takes
# precedence and is injected into only the spawned Python process. These values
# are never copied into a database Profile or DeepAgent config file.
MODEL_PROTOCOL=openai
MODEL_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-5.5
MODEL_API_KEY=

# DeepAgent web research still needs a Tavily key independently of the model
# Profile. It is passed to the backend/child process but is not stored in a model
# Profile. Leave blank if DeepAgent live research is not used.
TAVILY_API_KEY=

# Legacy local DeepAgent runtime adapter. Keep these only while
# AGENT_RUNTIME_TRANSPORT=local is used outside Compose.
DEEPAGENT_COMMAND=uv
DEEPAGENT_WORKDIR=../deepagent
DEEPAGENT_CONFIG=deepagent.toml
DEEPAGENT_REGISTRY=agents.json
DEEPAGENT_TIMEOUT_SECONDS=300
DEEPAGENT_CONCURRENCY=1

# Python Agent Runtime transport. Local is the safe direct-host default;
# Compose explicitly uses grpc and the internal agent-runtime service name.
AGENT_RUNTIME_TRANSPORT=local
AGENT_RUNTIME_GRPC_ADDRESS=127.0.0.1:50051
# Compose development uses explicit internal plaintext. Set false in
# production together with CA/client identity paths.
AGENT_RUNTIME_GRPC_INSECURE=true
AGENT_RUNTIME_GRPC_SERVER_NAME=
AGENT_RUNTIME_GRPC_CA_FILE=
AGENT_RUNTIME_GRPC_CLIENT_CERT_FILE=
AGENT_RUNTIME_GRPC_CLIENT_KEY_FILE=
AGENT_RUNTIME_LLM_TIMEOUT_SECONDS=45
AGENT_RUNTIME_DEEPAGENT_TIMEOUT_SECONDS=300
AGENT_RUNTIME_MAX_CONCURRENCY=4
AGENT_RUNTIME_DEEPAGENT_CONCURRENCY=1
AGENT_RUNTIME_MAX_PENDING=16
AGENT_RUNTIME_MAX_REQUEST_BYTES=8388608
AGENT_RUNTIME_MAX_EVENT_BYTES=4194304
AGENT_RUNTIME_MAX_ARTIFACT_BYTES=2097152
AGENT_RUNTIME_MAX_OUTPUT_BYTES=1048576
AGENT_RUNTIME_EVENT_BUFFER_SIZE=16
AGENT_RUNTIME_SHUTDOWN_GRACE_SECONDS=10

# Logging.
# LOG_FORMAT=text is convenient locally; use json for production log collectors.
LOG_LEVEL=info
LOG_FORMAT=text
LOG_ADD_SOURCE=false

# v0.2 security controls.
# ADMIN_API_KEY protects agent/knowledge write APIs when non-empty.
ADMIN_API_KEY=change_me_admin_key
# Public browser origin(s) for deployed frontend access.
# Leave blank for local-only startup, or set one/more comma-separated origins such as
# http://your-server-ip:5173 or https://agentroom.example.com before server deployment.
# Match the frontend host port you expose with FRONTEND_HOST_PORT.
PUBLIC_ORIGIN=
# Comma-separated production origins allowed to open WebSocket connections.
# Include both localhost forms for local Docker/browser access.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# MySQL persistence used by the backend when running directly on the host.
DB_DRIVER=mysql
MYSQL_DSN=agentroom:agentroom_password@tcp(127.0.0.1:3306)/agentroom?parseTime=true&charset=utf8mb4&loc=UTC
DB_AUTO_MIGRATE=true

# Docker Compose MySQL bootstrap values.
# The backend service overrides MYSQL_DSN to use the compose service hostname.
MYSQL_DATABASE=agentroom
MYSQL_USER=agentroom
MYSQL_PASSWORD=agentroom_password
MYSQL_ROOT_PASSWORD=change_me_root_password

# Frontend build-time admin key used by the internal management UI.
# For local Docker startup, keep this aligned with ADMIN_API_KEY.
VITE_ADMIN_API_KEY=change_me_admin_key
